{
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/trpc": "^1.1.0",
    "@inquirer/prompts": "^8.3.2",
    "copy-paste": "^2.2.0",
    "elysia": "^1.4.28",
    "mime": "^4.1.0",
    "pem": "^1.14.8",
    "qrcode-terminal": "^0.12.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "name": "ahh-binary",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "bun --env-file=.bun.env.local main.ts",
    "prod": "bun main.ts",
    "compile:dev": "bun build --compile --minify --sourcemap --env-file=.bun.env.local main.ts --outfile ./dist/bin/ahh-dev",
    "compile:prod": "bun build --compile --minify main.ts --outfile ./dist/bin/ahh",
    "completions:dev": "mkdir -p ./dist && AHH_COMPLETIONS=1 bun main.ts >> ./dist/_ahh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/yargs": "^17.0.35",
    "@types/copy-paste": "^2.1.0",
    "@types/pem": "^1.14.4",
    "@types/qrcode-terminal": "^0.12.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
