{
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/trpc": "^1.1.0",
    "@inquirer/prompts": "^8.3.2",
    "cli-table3": "^0.6.5",
    "copy-paste": "^2.2.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "mime": "^4.1.0",
    "openai": "^6.32.0",
    "pem": "^1.14.8",
    "qrcode-terminal": "^0.12.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "name": "ahh-binary",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "bun --env-file=.bun.env.local main.ts",
    "prod": "bun main.ts",
    "format": "prettier --write .",
    "compile:dev": "bun build --compile --minify --sourcemap --env-file=.bun.env.local main.ts --outfile ./dist/bin/ahh-dev",
    "compile:prod": "bun build --compile --minify --no-compile-autoload-dotenv --no-compile-autoload-bunfig main.ts --outfile ./dist/bin/ahh",
    "completions:dev": "mkdir -p ./dist && AHH_COMPLETIONS=1 bun main.ts >> ./dist/_ahh",
    "db:generate": "bunx drizzle-kit generate",
    "db:studio": "bunx drizzle-kit studio"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/copy-paste": "^2.1.0",
    "@types/pem": "^1.14.4",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/yargs": "^17.0.35",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
